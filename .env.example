SECRET_KEY=secret
JWT_SECRET_KEY=jwt_secret

# Local environment
ENVIRONMENT=local
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/conversations

# Staging environment
# ENVIRONMENT=staging
# DATABASE_URL=postgresql+psycopg://staging-user:staging-password@staging-url:staging-port/staging-db

# Production environment
# ENVIRONMENT=prod
# DATABASE_URL=postgresql+psycopg://prod-user:prod-password@prod-url:prod-port/prod-db

# R2
R2_ACCESS_KEY_ID=abc
R2_SECRET_ACCESS_KEY=abc
R2_ENDPOINT_URL=
R2_PUB_URL=
R2_BUCKET_NAME=conversations

# Transcription
# TRANSCRIPTION_PROVIDER=openai
# OPENAI_API_KEY=
# ELEVENLABS_API_KEY=

# Agent (LLM): openai | anthropic
# AGENT_PROVIDER=openai
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=

# Document extraction (Phase 2): docling_local | docling_modal
# DOCUMENT_PROCESSOR_TYPE=docling_local
# MAX_DOCUMENT_BYTES=52428800

# docling_modal: Modal deployed app + function (see modal_docling_app.py, scripts/modal/deploy_document_processor.sh)
# MODAL_DOCUMENT_APP_NAME=template-document-processor
# MODAL_DOCUMENT_FUNCTION_NAME=extract_markdown
# Modal credentials — read directly by the Modal SDK (not by Settings); required for docling_modal.
# Get them at: https://modal.com/settings/tokens  (Token ID starts with ak-, Secret with as-)
# MODAL_TOKEN_ID=ak-...
# MODAL_TOKEN_SECRET=as-...

# Set to empty to disable NSFW moderation
NSFW_PROVIDER=openai_moderation

# Message pipeline
# DEBOUNCE_MAX_MESSAGES=10        # max buffered payloads consumed per debounce burst
# AGENT_HISTORY_LIMIT=20          # recent messages fed to the agent as history
# MAX_ATTACHMENT_BYTES=26214400   # 25 MiB; attachments larger than this are dropped
